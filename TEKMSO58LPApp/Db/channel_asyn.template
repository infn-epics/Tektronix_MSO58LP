}

# The C engine itself.  Processed by the trigger calcouts below.
record(aSub, "$(P):CH$(CHANNEL):storeEngine_")
{
    field(DESC, "Per-channel store engine")
    field(SNAM, "tekStoreWaveform")
    field(INAM, "tekStoreWaveform_init")

    field(FTA,  "LONG")   field(NOA, "1")
    field(INPA, "$(P):CH$(CHANNEL):Store:Ctrl NPP NMS")

    field(FTB,  "CHAR")   field(NOB, "512")
    field(INPB, "$(P):Store:Path NPP NMS")

    field(FTC,  "CHAR")   field(NOC, "128")
    field(INPC, "$(P):Store:Basename NPP NMS")

    field(FTD,  "STRING") field(NOD, "1")
    field(INPD, "$(P):CH$(CHANNEL):Store:ChName NPP NMS")

    field(FTE,  "LONG")   field(NOE, "1")
    field(INPE, "$(P):Store:NumAcq NPP NMS")

    field(FTF,  "DOUBLE") field(NOF, "1")
    field(INPF, "$(P):CH$(CHANNEL):Xinc NPP NMS")

    field(FTG,  "DOUBLE") field(NOG, "1")
    field(INPG, "$(P):CH$(CHANNEL):Ymult NPP NMS")

    field(FTH,  "DOUBLE") field(NOH, "1")
    field(INPH, "$(P):CH$(CHANNEL):Yzero NPP NMS")

    field(FTI,  "DOUBLE") field(NOI, "1")
    field(INPI, "$(P):CH$(CHANNEL):Yoff NPP NMS")

    field(FTJ,  "DOUBLE") field(NOJ, "$(NELM)") field(NEVJ, "$(NELM)")
    field(INPJ, "$(P):CH$(CHANNEL):Waveform NPP NMS")

    field(FTK,  "LONG")   field(NOK, "1")
    field(INPK, "$(P):CH$(CHANNEL):NrPt NPP NMS")

    field(FTL,  "LONG")   field(NOL, "1")
    field(INPL, "$(P):CH$(CHANNEL):DataStart NPP NMS")

    field(FTVA, "LONG")   field(NOVA, "1")
    field(FTVB, "STRING") field(NOVB, "1")
    field(FTVC, "LONG")   field(NOVC, "1")

    field(OUTA, "$(P):CH$(CHANNEL):Store:Status PP")
    field(OUTB, "$(P):CH$(CHANNEL):Store:File PP")
    field(OUTC, "$(P):CH$(CHANNEL):Store:Count PP")

    field(FLNK, "$(P):CH$(CHANNEL):storeAutoStop_")
}

# After every engine processing, if status == 2 (NumAcq reached) clear
# the per-channel Active flag.
record(calcout, "$(P):CH$(CHANNEL):storeAutoStop_")
{
    field(DESC, "Auto-stop when NumAcq reached")
    field(INPA, "$(P):CH$(CHANNEL):Store:Status NPP NMS")
    field(CALC, "A=2?0:A")
    field(OOPT, "On Change")
    field(DOPT, "Use CALC")

record(bo, "$(P):CH$(CHANNEL):Store:Active")
{
    field(DESC, "Channel storage in progress")
    field(ZNAM, "Idle")
    field(ONAM, "Active")
    field(VAL,  "0")
    field(PINI, "YES")
}


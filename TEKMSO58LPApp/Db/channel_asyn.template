    field(OUT,  "$(P):CH$(CHANNEL):storeEngine_.PROC PP")
    field(FLNK, "$(P):CH$(CHANNEL):storeMarkActive_")
}
record(calcout, "$(P):CH$(CHANNEL):storeMarkActive_")
{
    field(DESC, "Mark channel as actively storing")
    field(INPA, "$(P):CH$(CHANNEL):Store:Status NPP NMS")
    field(CALC, "A=1?1:0")
    field(OOPT, "When Non-zero")
    field(DOPT, "Use CALC")
    field(OUT,  "$(P):CH$(CHANNEL):Store:Active NPP")
}

# Trigger on each DataReady tick when Active=1: set Ctrl=2 and PROC.
record(calcout, "$(P):CH$(CHANNEL):storeTick_")
{
    field(DESC, "Append row on DataReady")
    field(INPA, "$(P):CH$(CHANNEL):DataReady CP NMS")
    field(INPB, "$(P):CH$(CHANNEL):Store:Active NPP NMS")
    field(CALC, "B=1?2:0")
    field(OOPT, "When Non-zero")
    field(DOPT, "Use CALC")
    field(OUT,  "$(P):CH$(CHANNEL):Store:Ctrl PP")
    field(FLNK, "$(P):CH$(CHANNEL):storeTickProc_")
}
record(calcout, "$(P):CH$(CHANNEL):storeTickProc_")
{
    field(DESC, "Process engine for APPEND")
    field(INPA, "$(P):CH$(CHANNEL):Store:Ctrl NPP NMS")
    field(CALC, "A=2?1:0")
    field(OOPT, "When Non-zero")
    field(DOPT, "Use CALC")
    field(OUT,  "$(P):CH$(CHANNEL):storeEngine_.PROC PP")
}

# Trigger on global Store:Stop: force CLOSE if Active, regardless of
# Enable (so a session can always be aborted).
record(calcout, "$(P):CH$(CHANNEL):storeStopTrig_")
{
    field(DESC, "Abort storage")
    field(INPA, "$(P):Store:Stop CP NMS")
    field(INPB, "$(P):CH$(CHANNEL):Store:Active NPP NMS")
    field(CALC, "(A=1)&&(B=1)?3:0")
    field(OOPT, "When Non-zero")
    field(DOPT, "Use CALC")
    field(OUT,  "$(P):CH$(CHANNEL):Store:Ctrl PP")
    field(FLNK, "$(P):CH$(CHANNEL):storeStopProc_")
}
record(calcout, "$(P):CH$(CHANNEL):storeStopProc_")
{
    field(DESC, "Process engine for CLOSE")
    field(INPA, "$(P):CH$(CHANNEL):Store:Ctrl NPP NMS")
    field(CALC, "A=3?1:0")
    field(OOPT, "When Non-zero")
    field(DOPT, "Use CALC")
    field(OUT,  "$(P):CH$(CHANNEL):storeEngine_.PROC PP")
    field(FLNK, "$(P):CH$(CHANNEL):storeForceIdle_")
}
record(calcout, "$(P):CH$(CHANNEL):storeForceIdle_")
{
    field(DESC, "Clear Active after CLOSE")
    field(CALC, "0")
    field(DOPT, "Use CALC")
    field(OUT,  "$(P):CH$(CHANNEL):Store:Active NPP")
}

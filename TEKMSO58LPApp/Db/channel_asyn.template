{
    field(DESC, "Start storage on this channel")
    field(INPA, "$(P):Store:Start CP NMS")
    field(INPB, "$(P):CH$(CHANNEL):Store:Enable NPP NMS")
    field(CALC, "(A=1)&&(B=1)?1:0")

# ============================================================
# Marker Positions in Sample Numbers (user-writable)
# Window-relative sample index (0-indexed, 0..WindowSize-1) so they
# align with the OPI sample-index X axis. Converted to absolute time
# via Xinc and DataStart, then written to MarkerStart/MarkerEnd for
# driver stats computation.
# ============================================================
record(longout, "$(P):CH$(CHANNEL):MarkerStartPt")
{
    field(DESC, "Stats marker start (sample, window-rel)")
    field(VAL,  "0")
    field(PINI, "YES")
    field(DRVL, "0")
    field(EGU,  "pts")
    field(FLNK, "$(P):CH$(CHANNEL):computeMkrStartTime_")
}

record(calcout, "$(P):CH$(CHANNEL):computeMkrStartTime_")
{
    field(DESC, "Convert start sample to time")
    field(INPA, "$(P):CH$(CHANNEL):MarkerStartPt NPP NMS")
    field(INPB, "$(P):CH$(CHANNEL):Xinc CP NMS")
    field(INPC, "$(P):CH$(CHANNEL):DataStart CP NMS")
    field(CALC, "(A+C-1)*B")
    field(DOPT, "Use CALC")
    field(OOPT, "Every Time")
    field(OUT,  "$(P):CH$(CHANNEL):MarkerStart PP")
}

record(longout, "$(P):CH$(CHANNEL):MarkerEndPt")
{
    field(DESC, "Stats marker end (sample, window-rel)")
    field(VAL,  "0")
    field(DRVL, "0")
    field(EGU,  "pts")
    field(FLNK, "$(P):CH$(CHANNEL):computeMkrEndTime_")
}

record(calcout, "$(P):CH$(CHANNEL):computeMkrEndTime_")
{
    field(DESC, "Convert end sample to time")
    field(INPA, "$(P):CH$(CHANNEL):MarkerEndPt NPP NMS")
    field(INPB, "$(P):CH$(CHANNEL):Xinc CP NMS")
    field(INPC, "$(P):CH$(CHANNEL):DataStart CP NMS")
    field(CALC, "A>0?(A+C-1)*B:0")
    field(DOPT, "Use CALC")
    field(OOPT, "Every Time")
    field(OUT,  "$(P):CH$(CHANNEL):MarkerEnd PP")
}

# Reset markers to current data window boundaries
record(bo, "$(P):CH$(CHANNEL):ResetMarkers")
{
    field(DESC, "Reset markers to data window")
    field(ZNAM, "Idle")
    field(ONAM, "Reset")
    field(HIGH, "0.1")
    field(FLNK, "$(P):CH$(CHANNEL):resetMkr_Start_")
}

record(calcout, "$(P):CH$(CHANNEL):resetMkr_Start_")
{
    field(DESC, "Reset marker start to window begin (0)")
    field(CALC, "0")
    field(DOPT, "Use CALC")
    field(OUT,  "$(P):CH$(CHANNEL):MarkerStartPt PP")
    field(FLNK, "$(P):CH$(CHANNEL):resetMkr_End_")
}

record(calcout, "$(P):CH$(CHANNEL):resetMkr_End_")
{
    field(DESC, "Reset marker end to window end (WindowSize-1)")
    field(INPB, "$(P):CH$(CHANNEL):WindowSize NPP NMS")
    field(CALC, "B-1")
    field(DOPT, "Use CALC")
    field(OUT,  "$(P):CH$(CHANNEL):MarkerEndPt PP")
}

# ============================================================
# Snap markers to first threshold crossing
# FindMarkerStart : scans the current Waveform buffer LEFT->RIGHT,
#                   sets MarkerStartPt to the first index where
#                   |sample| > AutoThreshold.
# FindMarkerEnd   : scans RIGHT->LEFT, sets MarkerEndPt similarly.
# If nothing crosses threshold the marker is left at the window edge.
# ============================================================
record(bo, "$(P):CH$(CHANNEL):FindMarkerStart")
{
    field(DESC, "Snap start marker to first xing (L)")
    field(ZNAM, "Idle")
    field(ONAM, "Find")
    field(HIGH, "0.1")
    field(FLNK, "$(P):CH$(CHANNEL):findMkrStart_")
}

record(aSub, "$(P):CH$(CHANNEL):findMkrStart_")
{
    field(DESC, "Scan waveform L->R for threshold")
    field(SNAM, "findMarkerStart")

    field(FTA,  "DOUBLE") field(NOA, "1")
    field(INPA, "$(P):CH$(CHANNEL):AutoThreshold NPP NMS")

    field(FTC,  "DOUBLE") field(NOC, "$(NELM)") field(NEVC, "$(NELM)")
    field(INPC, "$(P):CH$(CHANNEL):Waveform NPP NMS")

    field(FTD,  "LONG")   field(NOD, "1")
    field(INPD, "$(P):CH$(CHANNEL):NrPt NPP NMS")

    field(FTVA, "LONG")   field(NOVA, "1")
    field(FTVB, "LONG")   field(NOVB, "1")

    field(OUTA, "$(P):CH$(CHANNEL):MarkerStartPt PP")
}

record(bo, "$(P):CH$(CHANNEL):FindMarkerEnd")
{
    field(DESC, "Snap end marker to first xing (R)")
    field(ZNAM, "Idle")
    field(ONAM, "Find")
    field(HIGH, "0.1")
    field(FLNK, "$(P):CH$(CHANNEL):findMkrEnd_")
}

record(aSub, "$(P):CH$(CHANNEL):findMkrEnd_")
{
    field(DESC, "Scan waveform R->L for threshold")
    field(SNAM, "findMarkerEnd")

    field(FTA,  "DOUBLE") field(NOA, "1")
    field(INPA, "$(P):CH$(CHANNEL):AutoThreshold NPP NMS")

    field(FTC,  "DOUBLE") field(NOC, "$(NELM)") field(NEVC, "$(NELM)")
    field(INPC, "$(P):CH$(CHANNEL):Waveform NPP NMS")

    field(FTD,  "LONG")   field(NOD, "1")
    field(INPD, "$(P):CH$(CHANNEL):NrPt NPP NMS")

    field(FTVA, "LONG")   field(NOVA, "1")
    field(FTVB, "LONG")   field(NOVB, "1")

    field(OUTA, "$(P):CH$(CHANNEL):MarkerEndPt PP")
}

